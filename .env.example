# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram (MTProto — your own account, not a bot) ───────────────────────────
# Get from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Where approval messages are sent:
#   'me'         = your Saved Messages (default — private, always accessible)
#   '-100xxxx'   = a dedicated group chat you control
TELEGRAM_APPROVAL_CHAT_ID=me

# ── WhatsApp (Baileys — optional) ──────────────────────────────────────────────
# No keys needed — QR code appears in terminal on first start.
# Set to 'true' to enable. Session stored in ~/.argos/whatsapp_session/
WHATSAPP_ENABLED=false

# ── Email (IMAP — optional) ────────────────────────────────────────────────────
# Gmail: use an App Password (Google Account → Security → App Passwords)
# Outlook: imap host = outlook.office365.com
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_MAILBOX=INBOX

# ── Notion ─────────────────────────────────────────────────────────────────────
# Create an integration at notion.so/my-integrations
# Share BOTH databases with the integration
NOTION_API_KEY=
# Agent workspace (tasks, notes, tx reviews — dedicated to Argos)
NOTION_AGENT_DATABASE_ID=
# Owner workspace (your personal todos — optional, for full workspace control)
NOTION_OWNER_DATABASE_ID=

# ── Google Calendar ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── Web app + WebAuthn / YubiKey ──────────────────────────────────────────────
APP_PORT=3000

# WebAuthn RP ID — MUST match the hostname/IP used to access the app from your phone.
# WebAuthn requires HTTPS for non-localhost origins.
# Options:
#   localhost       → only works on the same machine (no phone access)
#   192.168.x.x    → LAN IP (needs HTTPS — use mkcert or Tailscale)
#   argos.local     → mDNS hostname (needs HTTPS — use mkcert)
#   argos.yourdomain.com → proper HTTPS (Tailscale funnel or reverse proxy)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ── Paths ──────────────────────────────────────────────────────────────────────
DATA_DIR=~/.argos
CONFIG_PATH=~/.argos/config.json
