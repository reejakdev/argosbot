{
  "name": "argos",
  "version": "0.4.0",
  "description": "Argos — local-first AI assistant, privacy-preserving, human-approved",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/argos-ai/argos"
  },
  "homepage": "https://github.com/argos-ai/argos#readme",
  "bugs": {
    "url": "https://github.com/argos-ai/argos/issues"
  },
  "type": "module",
  "bin": {
    "argos": "bin/argos"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:client": "vite --config src/webapp/client/vite.config.ts",
    "build": "tsc",
    "build:public": "tsc --project tsconfig.public.json",
    "build:client": "vite build --config src/webapp/client/vite.config.ts",
    "build:all": "npm run build:client && npm run build",
    "build:all:public": "npm run build:client && npm run build:public",
    "start": "node dist/index.js",
    "setup": "tsx src/scripts/setup.ts",
    "restart": "tsx src/scripts/cli.ts restart",
    "stop": "tsx src/scripts/cli.ts stop",
    "dashboard": "tsx src/scripts/cli.ts dashboard",
    "status": "tsx src/scripts/cli.ts status",
    "logs": "tsx src/scripts/cli.ts logs",
    "dev:argos": "tsx src/scripts/cli.ts dev",
    "reauth": "tsx src/scripts/reauth.ts",
    "anon-test": "tsx src/scripts/anon-test.ts",
    "decrypt": "tsx src/scripts/decrypt.ts",
    "inject": "tsx src/scripts/inject.ts",
    "doctor": "tsx src/scripts/doctor.ts",
    "verify-audit": "tsx src/scripts/verify-audit.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.73.0",
    "@lancedb/lancedb": "0.27.1",
    "@mariozechner/pi-ai": "0.64.0",
    "@modelcontextprotocol/sdk": "1.28.0",
    "@notionhq/client": "2.3.0",
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.0.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "16.6.1",
    "express": "5.2.1",
    "googleapis": "144.0.0",
    "imapflow": "1.2.18",
    "mammoth": "1.12.0",
    "node-cron": "3.0.3",
    "otpauth": "9.5.0",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.2",
    "telegram": "2.26.22",
    "ulid": "2.4.0",
    "viem": "2.47.6",
    "ws": "8.20.0",
    "xlsx": "0.18.5",
    "zod": "3.25.76"
  },
  "optionalDependencies": {
    "@slack/socket-mode": "2.0.6",
    "@slack/web-api": "7.15.0",
    "@solana/web3.js": "1.98.4",
    "@whiskeysockets/baileys": "6.7.21",
    "discord.js": "14.0.0",
    "keytar": "7.9.0",
    "nodemailer": "6.10.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.6",
    "@types/node": "22.18.13",
    "@types/node-cron": "3.0.11",
    "@types/nodemailer": "7.0.11",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
